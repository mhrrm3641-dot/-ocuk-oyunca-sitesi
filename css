<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GLOBAL CYBER BASE</title>
    
    <style>
        /* Tasarımı esnek hale getiren ana CSS */
        body { margin: 0; padding: 10px; font-family: sans-serif; }
        .container { max-width: 100%; width: 100%; box-sizing: border-box; }
        
        /* Modüllerin mobil cihazda alt alta gelmesi için: */
        .modul-grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); 
            gap: 15px; 
        }
        
        /* Terminalin ekran dışına taşmaması için: */
        #analiz-ekrani { 
            background: #000; color: #0f0; padding: 10px; 
            border-radius: 5px; overflow-x: auto; 
            word-wrap: break-word; white-space: pre-wrap; 
            max-width: 100%; 
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="vizyon-header">
            <h1>GLOBAL CYBER BASE</h1>
        </div>

        <div class="modul-grid">
            <div class="modul-kart">🛡️ Siber Savunma</div>
            <div class="modul-kart">🧠 Yapay Zeka</div>
        </div>

        <section id="cyber-news" style="margin: 20px 0; border: 1px solid #ddd; padding: 10px;">
            <h3>🌐 Cyber News</h3>
            <div id="news-content"></div>
        </section>

        <div id="terminal-kapsayici">
            <pre id="analiz-ekrani">// Sistem verileri bekleniyor...</pre>
        </div>
    </div>

    <script>
        // Haberleri ve terminali burada çalıştır
    </script>
</body>
</html>
